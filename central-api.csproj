<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>CentralApi</RootNamespace>
    <!-- webapp/ holds the React sources (and node_modules); only its Vite build
         output in wwwroot/ belongs to the API. Without this, dotnet build tries
         to compile/copy the whole npm tree. -->
    <DefaultItemExcludes>$(DefaultItemExcludes);webapp\**</DefaultItemExcludes>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Dapper" Version="2.1.35" />
    <PackageReference Include="Npgsql" Version="8.0.3" />
  </ItemGroup>

</Project>
