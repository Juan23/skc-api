# Copy to .env.playwright (gitignored) and fill in real values.
# Never commit .env.playwright - it holds a real, working till login.

# Reuse the same zz-gaisano test till already used for Claude-in-Chrome POS
# testing (see skc-api/CLAUDE.md "Claude-in-Chrome POS testing") - a Gaisano
# Branch account, tagged `zz-` so it's part of the same one-shot test-data
# cleanup index. Ask the owner for its password rather than inventing a new
# test account.
PLAYWRIGHT_BRANCH_USERNAME=zz-gaisano
PLAYWRIGHT_BRANCH_PASSWORD=

# zz-owner: a persistent TEST Owner-role account for click-testing owner-gated
# screens (Recipes, prices). zz-tagged for the cleanup sweep; owner writes stay
# IP-gated (both layers), so it only works from an owner-IP device. Ask for the
# password (kept in the real .env.playwright, gitignored).
PLAYWRIGHT_OWNER_USERNAME=zz-owner
PLAYWRIGHT_OWNER_PASSWORD=

# The 4-digit PIN the POS specs seed for the `test-cashier` picker row
# (Gaisano). Test-only, not a secret - any 4 digits work; the specs reset the
# row's PIN to this value on every run, so it can't drift.
PLAYWRIGHT_STAFF_PIN=2468

# Optional override - defaults to the Tailscale HTTPS origin in
# playwright.config.ts (must be HTTPS: the session cookie is Secure-only).
# PLAYWRIGHT_BASE_URL=https://skc-hq.tail0988bb.ts.net
